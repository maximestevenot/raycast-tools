{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "brandkit",
  "title": "Brandkit",
  "description": "Quickly find and copy colors from your design system.",
  "icon": "extension-icon.png",
  "author": "maxime",
  "categories": ["Design Tools", "Developer Tools"],
  "license": "MIT",
  "commands": [
    {
      "name": "search-colors",
      "title": "Search Colors",
      "subtitle": "Brandkit",
      "description": "Search design system colors and copy them to the clipboard.",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.99.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "test": "vitest run",
    "publish": "npx @raycast/api@latest publish"
  }
}
